# Text Files (Modify line endings to windows format)
*      text eol=crlf
*.js   text eol=crlf
*.ts   text eol=crlf
*.json text eol=crlf
*.xml  text eol=crlf
*.yml  text eol=crlf
*.yaml text eol=crlf
*.svg  text eol=crlf
*.map  text eol=crlf

# Binary files (does not modify)
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.woff binary
*.woff2 binary
*.ttf  binary
*.zip  binary
*.gz   binary
*.rar  binary

# Shell scripts must use LF
*.sh   text eol=lf

# PowerShell scripts
*.ps1  text eol=crlf

# Docs/plans — use union merge to reduce conflicts when multiple devs
# add plan files concurrently. Union merge accepts both sides.
docs/plans/** merge=union
docs/brainstorms/** merge=union
